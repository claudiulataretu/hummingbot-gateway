{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "slippagePct": {
      "type": "number",
      "description": "Default slippage percentage (e.g., 2 for 2%)"
    },
    "gasLimitEstimate": {
      "type": "number",
      "description": "Gas limit for a single swap"
    },
    "routerAbi": {
      "type": "string",
      "description": "Router abi path"
    },
    "pairAbi": {
      "type": "string",
      "description": "Pair abi path"
    }
  },
  "additionalProperties": false,
  "required": ["slippagePct", "gasLimitEstimate", "routerAbi", "pairAbi"]
}
