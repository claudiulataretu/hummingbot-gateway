{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "chainID": { "type": "integer" },
    "nodeURL": { "type": "string" },
    "nativeCurrencySymbol": { "type": "string" },
    "swapProvider": {
      "type": "string",
      "description": "Default swap router provider for this network (format: connector/type, e.g., xexchange/amm)",
      "default": "xexchange/amm"
    },
    "minGasPrice": {
      "type": "number",
      "description": "Minimum gas price in EGLD"
    },
    "rpcProvider": {
      "type": "string",
      "description": "RPC provider name (e.g., 'url')",
      "default": "url"
    }
  },
  "required": ["chainID", "nodeURL", "nativeCurrencySymbol"],
  "additionalProperties": false
}
